pipeline {
    agent any
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }
    
    environment {
        PYTHON_VERSION = '3.9'
        SONAR_PROJECT_KEY = 'flask-api-backend'
        SONAR_HOST_URL = 'http://localhost:9000'
        MODULE_DIR = 'BackendServicePython'
    }
    
    stages {
        stage('Execute Module Pipeline') {
            steps {
                script {
                    // Everything inside this script block stays in the subfolder
                    dir("${env.MODULE_DIR}") {
                        
                        stage('Setup') {
                            echo '========== Setting up environment =========='
                            bat '''
                                python --version
                                python -m pip install --upgrade pip
                                pip install -r requirements.txt
                                pip install pytest pytest-cov pytest-json-report
                            '''
                        }
                        
                        stage('Lint') {
                            echo '========== Running code quality checks =========='
                            bat '''
                                pip install flake8
                                python -m flake8 app.py test_app.py --count --select=E9,F63,F7,F82 --show-source --statistics || exit 0
                                python -m flake8 app.py test_app.py --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics || exit 0
                            '''
                        }
                        
                        stage('Unit Tests') {
                            echo '========== Running unit tests =========='
                            bat '''
                                python -m pytest test_app.py ^
                                    --cov=app ^
                                    --cov-report=xml ^
                                    --cov-report=html ^
                                    --cov-report=term ^
                                    --junitxml=test-results.xml ^
                                    --json-report ^
                                    --json-report-file=report.json ^
                                    -v
                            '''
                        }
                        
                        stage('Code Coverage') {
                            echo '========== Checking code coverage =========='
                            bat '''
                                python -m coverage report
                                python -m coverage html
                            '''
                            publishHTML([
                                reportDir: 'htmlcov',
                                reportFiles: 'index.html',
                                reportName: 'Code Coverage Report'
                            ])
                        }
                        
                        stage('SonarQube Analysis') {
                            try {
                                withSonarQubeEnv('SonarQube') {
                                    bat '''
                                        python -m sonar-scanner ^
                                            -Dsonar.projectKey=%SONAR_PROJECT_KEY% ^
                                            -Dsonar.sources=. ^
                                            -Dsonar.exclusions=venv/**,tests/**,.git/** ^
                                            -Dsonar.python.coverage.reportPaths=coverage.xml ^
                                            -Dsonar.test.inclusions=test_*.py ^
                                            -Dsonar.tests=. ^
                                            -Dsonar.host.url=%SONAR_HOST_URL%
                                    '''
                                }
                            } catch (Exception e) {
                                echo "Warning: SonarQube analysis failed, but continuing pipeline"
                            }
                        }
                    }
                }
            }
        }
    }
    
    post {
        always {
            echo '========== Cleaning up =========='
            // Reference paths relative to root for the Jenkins UI listeners
            junit testResults: "${env.MODULE_DIR}/test-results.xml", allowEmptyResults: true
            archiveArtifacts artifacts: "${env.MODULE_DIR}/htmlcov/**", allowEmptyArchive: true
            archiveArtifacts artifacts: "${env.MODULE_DIR}/coverage.xml", allowEmptyArchive: true
        }
    }
}