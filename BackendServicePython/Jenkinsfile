pipeline {
    agent any
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }
    
    environment {
        PYTHON_VERSION = '3.9'
        SONAR_PROJECT_KEY = 'flask-api-backend'
        SONAR_HOST_URL = 'http://localhost:9000'
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '========== Checking out code =========='
                checkout scm
            }
        }
        
        stage('Setup') {
            steps {
                echo '========== Setting up environment =========='
                bat '''
                    python --version
                    python -m pip install --upgrade pip
                    pip install -r requirements.txt
                    pip install pytest pytest-cov pytest-json-report
                '''
            }
        }
        
        stage('Lint') {
            steps {
                echo '========== Running code quality checks =========='
                bat '''
                    pip install flake8
                    python -mflake8 app.py test_app.py --count --select=E9,F63,F7,F82 --show-source --statistics || exit 0
                    python -m flake8 app.py test_app.py --count --exit-zero --max-complexity=10 --max-line-length=127 --statistics || exit 0
                '''
            }
        }
        
        stage('Unit Tests') {
            steps {
                echo '========== Running unit tests =========='
                bat '''
                    pytest test_app.py ^
                        --cov=app ^
                        --cov-report=xml ^
                        --cov-report=html ^
                        --cov-report=term ^
                        --junitxml=test-results.xml ^
                        --json-report ^
                        --json-report-file=report.json ^
                        -v
                '''
            }
        }
        
        stage('Code Coverage') {
            steps {
                echo '========== Checking code coverage =========='
                bat '''
                    coverage report
                    coverage html
                '''
                publishHTML([
                    reportDir: 'htmlcov',
                    reportFiles: 'index.html',
                    reportName: 'Code Coverage Report'
                ])
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                echo '========== Running SonarQube analysis =========='
                script {
                    try {
                        withSonarQubeEnv('SonarQube') {
                            bat '''
                                sonar-scanner.bat ^
                                    -Dsonar.projectKey=%SONAR_PROJECT_KEY% ^
                                    -Dsonar.sources=. ^
                                    -Dsonar.exclusions=venv/**,tests/**,.git/** ^
                                    -Dsonar.python.coverage.reportPaths=coverage.xml ^
                                    -Dsonar.test.inclusions=test_*.py ^
                                    -Dsonar.tests=. ^
                                    -Dsonar.host.url=%SONAR_HOST_URL%
                            '''
                        }
                    } catch (Exception e) {
                        echo "Warning: SonarQube analysis failed, but continuing pipeline"
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                echo '========== Checking SonarQube quality gate =========='
                script {
                    try {
                        timeout(time: 5, unit: 'MINUTES') {
                            waitForQualityGate abortPipeline: false
                        }
                    } catch (Exception e) {
                        echo "Warning: Quality gate check failed, but continuing pipeline"
                    }
                }
            }
        }
        
        stage('Build') {
            steps {
                echo '========== Building application =========='
                bat '''
                    echo Build stage - packaging application
                '''
            }
        }
        
        stage('Deploy to Dev') {
            when {
                branch 'main'
            }
            steps {
                echo '========== Deploying to Dev environment =========='
                bat '''
                    echo Deployment script would go here
                '''
            }
        }
    }
    
    post {
        always {
            echo '========== Cleaning up =========='
            
            // Publish test results
            junit testResults: 'test-results.xml', allowEmptyResults: true
            
            // Archive coverage reports
            archiveArtifacts artifacts: 'htmlcov/**', allowEmptyArchive: true
            archiveArtifacts artifacts: 'coverage.xml', allowEmptyArchive: true
        }
        
        success {
            echo '========== Build SUCCESS =========='
        }
        
        failure {
            echo '========== Build FAILED =========='
        }
    }
}
